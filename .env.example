# Copy to ".env" in this folder and adjust values. ".env" is gitignored.
# Loaded automatically when you start the app via main() (e.g. mvn spring-boot:run).
# OS environment variables always win over this file.

# --- Database (PostgreSQL) ---
DB_URL=jdbc:postgresql://localhost:5432/assetflow
DB_USERNAME=postgres
DB_PASSWORD=change_me

# --- Seeded SUPER_ADMIN (only created if no user exists with ADMIN_EMAIL) ---
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=change_me

# --- Optional ---
# SERVER_PORT=8080
# JPA_DDL_AUTO=update
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
