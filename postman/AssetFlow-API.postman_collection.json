{
	"info": {
		"_postman_id": "assetflow-api-collection",
		"name": "AssetFlow API",
		"description": "AssetFlow REST API – auth, organizations, users, roles, assets, bookings, maintenance, audit logs.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8080" }
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"secret123\",\n  \"fullName\": \"Jane Doe\",\n  \"roleId\": 1,\n  \"organizationId\": 1\n}"
						},
						"url": "{{baseUrl}}/api/auth/register",
						"description": "Create a new user. roleId required; organizationId optional."
					}
				},
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"secret123\"\n}"
						},
						"url": "{{baseUrl}}/api/auth/login",
						"description": "Authenticate; response sets session cookie for subsequent requests."
					}
				},
				{
					"name": "Me",
					"request": {
						"method": "GET",
						"url": "{{baseUrl}}/api/auth/me",
						"description": "Current authenticated user. Requires session from Login."
					}
				}
			]
		},
		{
			"name": "Organizations",
			"item": [
				{ "name": "List", "request": { "method": "GET", "url": "{{baseUrl}}/api/organizations" } },
				{ "name": "Get by id", "request": { "method": "GET", "url": "{{baseUrl}}/api/organizations/1" } },
				{
					"name": "Create",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"name\": \"Acme Corp\"\n}" },
						"url": "{{baseUrl}}/api/organizations"
					}
				},
				{
					"name": "Update",
					"request": {
						"method": "PUT",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"name\": \"Acme Corp Updated\"\n}" },
						"url": "{{baseUrl}}/api/organizations/1"
					}
				},
				{ "name": "Delete", "request": { "method": "DELETE", "url": "{{baseUrl}}/api/organizations/1" } }
			]
		},
		{
			"name": "Roles",
			"item": [
				{ "name": "List", "request": { "method": "GET", "url": "{{baseUrl}}/api/roles" } },
				{ "name": "Get by id", "request": { "method": "GET", "url": "{{baseUrl}}/api/roles/1" } },
				{
					"name": "Create",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"name\": \"Staff\"\n}" },
						"url": "{{baseUrl}}/api/roles"
					}
				},
				{
					"name": "Update",
					"request": {
						"method": "PUT",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"name\": \"Staff Updated\"\n}" },
						"url": "{{baseUrl}}/api/roles/1"
					}
				},
				{ "name": "Delete", "request": { "method": "DELETE", "url": "{{baseUrl}}/api/roles/1" } }
			]
		},
		{
			"name": "Users",
			"item": [
				{ "name": "List", "request": { "method": "GET", "url": "{{baseUrl}}/api/users" } },
				{ "name": "List by organization", "request": { "method": "GET", "url": "{{baseUrl}}/api/users?organizationId=1" } },
				{ "name": "Get by id", "request": { "method": "GET", "url": "{{baseUrl}}/api/users/1" } },
				{
					"name": "Create",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"newuser@example.com\",\n  \"passwordHash\": \"$2a$10$...\",\n  \"fullName\": \"New User\",\n  \"role\": { \"id\": 1 },\n  \"organization\": { \"id\": 1 }\n}"
						},
						"url": "{{baseUrl}}/api/users",
						"description": "Prefer POST /api/auth/register for new users (hashes password). This expects passwordHash."
					}
				},
				{
					"name": "Update",
					"request": {
						"method": "PUT",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"updated@example.com\",\n  \"fullName\": \"Updated Name\",\n  \"role\": { \"id\": 1 },\n  \"organization\": { \"id\": 1 }\n}"
						},
						"url": "{{baseUrl}}/api/users/1"
					}
				},
				{ "name": "Delete", "request": { "method": "DELETE", "url": "{{baseUrl}}/api/users/1" } }
			]
		},
		{
			"name": "Asset categories",
			"item": [
				{ "name": "List", "request": { "method": "GET", "url": "{{baseUrl}}/api/asset-categories" } },
				{ "name": "List by organization", "request": { "method": "GET", "url": "{{baseUrl}}/api/asset-categories?organizationId=1" } },
				{ "name": "Get by id", "request": { "method": "GET", "url": "{{baseUrl}}/api/asset-categories/1" } },
				{
					"name": "Create",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Laptops\",\n  \"organization\": { \"id\": 1 }\n}"
						},
						"url": "{{baseUrl}}/api/asset-categories"
					}
				},
				{
					"name": "Update",
					"request": {
						"method": "PUT",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Laptops & Tablets\",\n  \"organization\": { \"id\": 1 }\n}"
						},
						"url": "{{baseUrl}}/api/asset-categories/1"
					}
				},
				{ "name": "Delete", "request": { "method": "DELETE", "url": "{{baseUrl}}/api/asset-categories/1" } }
			]
		},
		{
			"name": "Assets",
			"item": [
				{ "name": "List", "request": { "method": "GET", "url": "{{baseUrl}}/api/assets" } },
				{ "name": "List by organization", "request": { "method": "GET", "url": "{{baseUrl}}/api/assets?organizationId=1" } },
				{ "name": "Get by id", "request": { "method": "GET", "url": "{{baseUrl}}/api/assets/1" } },
				{
					"name": "Create",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"MacBook Pro\",\n  \"description\": \"Company laptop\",\n  \"status\": \"AVAILABLE\",\n  \"organization\": { \"id\": 1 },\n  \"category\": { \"id\": 1 }\n}"
						},
						"url": "{{baseUrl}}/api/assets",
						"description": "status: AVAILABLE | RESERVED | IN_USE | UNDER_MAINTENANCE"
					}
				},
				{
					"name": "Update",
					"request": {
						"method": "PUT",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"MacBook Pro 2024\",\n  \"description\": \"Updated\",\n  \"status\": \"IN_USE\",\n  \"organization\": { \"id\": 1 },\n  \"category\": { \"id\": 1 }\n}"
						},
						"url": "{{baseUrl}}/api/assets/1"
					}
				},
				{ "name": "Delete", "request": { "method": "DELETE", "url": "{{baseUrl}}/api/assets/1" } }
			]
		},
		{
			"name": "Bookings",
			"item": [
				{ "name": "List", "request": { "method": "GET", "url": "{{baseUrl}}/api/bookings" } },
				{ "name": "List by organization", "request": { "method": "GET", "url": "{{baseUrl}}/api/bookings?organizationId=1" } },
				{ "name": "Get by id", "request": { "method": "GET", "url": "{{baseUrl}}/api/bookings/1" } },
				{
					"name": "Create",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"organization\": { \"id\": 1 },\n  \"asset\": { \"id\": 1 },\n  \"user\": { \"id\": 1 },\n  \"startTime\": \"2025-03-10T09:00:00Z\",\n  \"endTime\": \"2025-03-10T17:00:00Z\",\n  \"status\": \"PENDING\"\n}"
						},
						"url": "{{baseUrl}}/api/bookings",
						"description": "status: PENDING | APPROVED | REJECTED | COMPLETED"
					}
				},
				{
					"name": "Update",
					"request": {
						"method": "PUT",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"organization\": { \"id\": 1 },\n  \"asset\": { \"id\": 1 },\n  \"user\": { \"id\": 1 },\n  \"startTime\": \"2025-03-10T09:00:00Z\",\n  \"endTime\": \"2025-03-10T17:00:00Z\",\n  \"status\": \"APPROVED\"\n}"
						},
						"url": "{{baseUrl}}/api/bookings/1"
					}
				},
				{ "name": "Delete", "request": { "method": "DELETE", "url": "{{baseUrl}}/api/bookings/1" } }
			]
		},
		{
			"name": "Maintenance records",
			"item": [
				{ "name": "List", "request": { "method": "GET", "url": "{{baseUrl}}/api/maintenance-records" } },
				{ "name": "List by organization", "request": { "method": "GET", "url": "{{baseUrl}}/api/maintenance-records?organizationId=1" } },
				{ "name": "Get by id", "request": { "method": "GET", "url": "{{baseUrl}}/api/maintenance-records/1" } },
				{
					"name": "Create",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"organization\": { \"id\": 1 },\n  \"asset\": { \"id\": 1 },\n  \"description\": \"Screen replacement\",\n  \"startedAt\": \"2025-03-01T10:00:00Z\",\n  \"createdBy\": { \"id\": 1 }\n}"
						},
						"url": "{{baseUrl}}/api/maintenance-records"
					}
				},
				{
					"name": "Update",
					"request": {
						"method": "PUT",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"organization\": { \"id\": 1 },\n  \"asset\": { \"id\": 1 },\n  \"description\": \"Screen replacement done\",\n  \"startedAt\": \"2025-03-01T10:00:00Z\",\n  \"completedAt\": \"2025-03-01T14:00:00Z\"\n}"
						},
						"url": "{{baseUrl}}/api/maintenance-records/1"
					}
				},
				{ "name": "Delete", "request": { "method": "DELETE", "url": "{{baseUrl}}/api/maintenance-records/1" } }
			]
		},
		{
			"name": "Audit logs",
			"item": [
				{
					"name": "List by organization (paginated)",
					"request": {
						"method": "GET",
						"url": "{{baseUrl}}/api/audit-logs?organizationId=1&page=0&size=20",
						"description": "organizationId required. page/size optional (default size 20)."
					}
				},
				{ "name": "Get by id", "request": { "method": "GET", "url": "{{baseUrl}}/api/audit-logs/1" } }
			]
		}
	]
}
